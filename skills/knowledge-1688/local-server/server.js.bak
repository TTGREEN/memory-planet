// local-server/server.js - 鏈湴鏍稿績鏈嶅姟锛堟棤鏁版嵁搴撲緷璧栫増锛?// 鑱岃矗锛氳涔夋悳绱€乪mbedding 璁＄畻銆佸叧閿瘝绠＄悊
// 鏁版嵁婧愶細keywords.json锛堝唴瀛樺姞杞斤級

import express from 'express';
import cors from 'cors';
import { EmbeddingManager } from './embedding_manager.js';
import { SemanticRanker } from './semantic_ranker.js';
import { readFileSync, existsSync, writeFileSync } from 'fs';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

// 鏂板锛氬苟琛?embedding 涓庢€ц兘鐩戞帶
import EmbeddingWorkerPool from './worker-pool.js';
import { PerformanceMonitor, middleware } from './performance-monitor.js';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

const app = express();
const PORT = 11456;

// ========== 鍒濆鍖栫粍浠?==========
const workerPool = new EmbeddingWorkerPool({ workers: 4, timeoutMs: 30000 });
await workerPool.initialize();
console.log(`鈿?WorkerPool 宸插惎鍔? ${workerPool.workerCount} workers`);

const monitor = new PerformanceMonitor({
  slowThresholdMs: 1000,
  memoryHighWatermark: 1024 * 1024 * 1024
});
monitor.scheduleAutoReport(3600000); // 姣忓皬鏃惰嚜鍔ㄦ姤鍛?console.log(`馃搳 PerformanceMonitor 宸插惎鐢╜);

// ========== 涓棿浠?==========
app.use(cors({ origin: '*' }));
app.use(express.json());
app.use(monitor.middleware(monitor)); // 鎬ц兘鐩戞帶涓棿浠?
// ========== 鍔犺浇鍏抽敭璇嶅簱 ==========
const KEYWORDS_FILE = 'C:/Users/Administrator/.openclaw/workspace/skills/knowledge-1688-scraper/1688-ext/keywords.json';
let keywords = [];  // [{ word, heat, type, category }]

async function loadKeywords() {
  try {
    const data = readFileSync(KEYWORDS_FILE, 'utf8');
    keywords = JSON.parse(data);
    console.log(`鉁?鍏抽敭璇嶅簱宸插姞杞? ${keywords.length} 鏉);

    // 鍒濆鍖?ranker 骞惰缁?TF-IDF
    ranker.keywords = keywords;
    await ranker.initializeTFIDF(keywords);
  } catch (err) {
    console.error('鉂?鍏抽敭璇嶅簱鍔犺浇澶辫触:', err.message);
    console.error(`   璺緞: ${KEYWORDS_FILE}`);
    keywords = [];
  }
}

loadKeywords();

// ========== 鍒濆鍖?ranker ==========
const ranker = new SemanticRanker({ provider: 'ollama' });
console.log(`馃 SemanticRanker 宸插垵濮嬪寲 (provider: ${ranker.embedding.provider})`);

// ========== 闄愭祦鍣?==========
const rateLimiter = new (await import('./rate_limiter.js')).RateLimiter(10, 20);

// ========== 璺敱 ==========

/**
 * POST /api/search/semantic - 璇箟鎼滅储
 * Body: { query: string, limit?: number }
 */
app.post('/api/search/semantic', async (req, res) => {
  try {
    const { query, limit = 5 } = req.body;
    if (!query) return res.status(400).json({ error: '缂哄皯 query' });

    console.log(`馃攳 璇箟鎼滅储: "${query}" (type: ${typeof query}, len: ${query.length})`);
    console.log(`   鍏抽敭璇嶅簱澶у皬: ${keywords.length}`);

    // 1. BM25 鍒濈瓫
    const candidates = await getBM25Candidates(query, 50);
    console.log(`   BM25 鍊欓€夋暟: ${candidates.length}`);
    if (candidates.length > 0) {
      console.log(`   鍓?涓€欓€? ${candidates.slice(0,3).map(c => c.word).join(', ')}`);
    }

    // 2. 璇箟閲嶆帓
    const results = await ranker.rerank(query, candidates, limit);
    console.log(`   璇箟閲嶆帓瀹屾垚: ${results.length} 鏉);

    res.json({ success: true, query, results });
  } catch (err) {
    console.error('鉂?鎼滅储澶辫触:', err);
    res.status(500).json({ error: err.message });
  }
});

/**
 * GET /api/keywords/search - BM25 鎼滅储
 * Query: ?q=xxx&limit=5
 */
app.get('/api/keywords/search', async (req, res) => {
  const { q, limit = 5 } = req.query;
  if (!q) return res.status(400).json({ error: '缂哄皯 q 鍙傛暟' });

  try {
    const results = await getBM25Candidates(q, parseInt(limit));
    console.log(`[BM25] q="${q}" 鈫?${results.length} 鏉);
    res.json({ success: true, query: q, results });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

/**
 * POST /api/embed - 鎵归噺 embedding锛堝苟琛岃绠楋級
 * Body: { texts: string[] }
 */
app.post('/api/embed', async (req, res) => {
  try {
    await rateLimiter.acquire();

    const { texts } = req.body;
    if (!Array.isArray(texts) || texts.length === 0) {
      return res.status(400).json({ error: 'texts 蹇呴』鏄潪绌烘暟缁? });
    }

    // 骞惰 embedding锛圵orker 姹狅級
    const embeddings = await workerPool.embedBatch(texts);

    res.json({ success: true, embeddings });
  } catch (err) {
    console.error('鉂?Embedding 澶辫触:', err);
    res.status(500).json({ error: err.message });
  }
});

/**
 * GET /api/health - 鍋ュ悍妫€鏌? */
app.get('/api/health', (req, res) => {
  res.json({
    status: 'ok',
    provider: ranker.embedding.provider,
    cacheSize: ranker.embedding.cache.size,
    keywordsCount: keywords.length,
    timestamp: new Date().toISOString()
  });
});

/**
 * GET /api/stats - 缁熻
 */
app.get('/api/stats', (req, res) => {
  res.json({
    totalKeywords: keywords.length,
    provider: ranker.embedding.provider,
    rateLimit: rateLimiter.getStatus(),
    cacheSize: ranker.embedding.cache.size
  });
});

/**
 * POST /api/keywords/update - 鏇存柊鍏抽敭璇嶅簱锛堜粠鎵╁睍鍚屾锛? * Body: { keywords: [...] }
 */
app.post('/api/keywords/update', (req, res) => {
  const { keywords: newKeywords } = req.body;
  if (!Array.isArray(newKeywords)) {
    return res.status(400).json({ error: 'keywords 蹇呴』鏄暟缁? });
  }

  keywords = newKeywords;
  console.log(`鉁?鍏抽敭璇嶅簱宸叉洿鏂? ${keywords.length} 鏉);

  // 鎸佷箙鍖栧埌鏂囦欢锛堝彲閫夛級
  try {
    writeFileSync(KEYWORDS_FILE, JSON.stringify(keywords, null, 2), 'utf8');
  } catch (err) {
    console.warn('鈿狅笍 鍏抽敭璇嶅簱淇濆瓨澶辫触:', err.message);
  }

  res.json({ success: true, count: keywords.length });
});

// ========== 宸ュ叿鍑芥暟 ==========

/**
 * BM25 鍊欓€夐泦锛堝唴瀛樻枃鏈尮閰嶏級
 * keywords 瀛楁锛歿 word, heat, type }
 */
async function getBM25Candidates(query, limit = 50) {
  const lowerQuery = query.toLowerCase();
  const scores = new Map();

  for (const kw of keywords) {
    const word = (kw.word || '').toLowerCase();
    if (!word) continue;

    // 鏂囨湰鍖归厤寰楀垎锛堝瓙涓插寘鍚級
    let score = 0;
    if (word.includes(lowerQuery)) {
      score += 1.0;  // 鍏抽敭璇嶅寘鍚煡璇㈣瘝锛堝 "閾堕」閾? 鍖呭惈 "椤归摼"锛?    }
    if (lowerQuery.includes(word)) {
      score += 0.5;  // 鏌ヨ璇嶅寘鍚叧閿瘝锛堢煭璇嶅尮閰嶏級
    }

    if (score > 0) {
      // 鐑害鍔犳潈锛坙og 骞虫粦锛?      const heatScore = Math.log10((kw.heat || 1) + 1) * 0.1;
      scores.set(kw.word, { ...kw, score: score + heatScore });
    }
  }

  // 鎺掑簭鍙?top
  return Array.from(scores.values())
    .sort((a, b) => b.score - a.score)
    .slice(0, limit);
}

// ========== 鍚姩 ==========
app.listen(PORT, () => {
  console.log(`馃殌 鏈湴鏈嶅姟宸插惎鍔? http://localhost:${PORT}`);
  console.log(`馃摗 鎺ュ彛:`);
  console.log(`   POST /api/search/semantic  - 璇箟鎼滅储`);
  console.log(`   GET  /api/keywords/search  - BM25 鎼滅储`);
  console.log(`   POST /api/embed            - 鎵归噺 embedding (骞惰)`);
  console.log(`   POST /api/keywords/update  - 鏇存柊鍏抽敭璇嶅簱`);
  console.log(`   GET  /api/health           - 鍋ュ悍妫€鏌);
  console.log(`   GET  /api/stats            - 缁熻`);
  console.log(`   GET  /api/performance      - 鎬ц兘蹇収`);
});

// ========== 鎬ц兘鎶ュ憡绔偣 ==========
app.get('/api/performance', (req, res) => {
  res.json(monitor.snapshot());
});

// ========== 浼橀泤閫€鍑?==========
process.on('SIGINT', async () => {
  console.log('\n馃憢 鍏抽棴鏈嶅姟...');
  await workerPool.terminate();
  process.exit(0);
});


